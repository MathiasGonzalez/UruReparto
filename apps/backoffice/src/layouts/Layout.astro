---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — UruReparto</title>
  </head>
  <body class="bg-gray-50 text-gray-900 min-h-screen">
    <nav class="bg-white border-b border-gray-200 shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2 font-bold text-xl text-blue-700">
          📦 UruReparto
        </a>
        <div class="flex items-center gap-6 text-sm font-medium">
          <a href="/stock" class="hover:text-blue-700 transition-colors">Stock</a>
          <a href="/deliveries" class="hover:text-blue-700 transition-colors">Envíos</a>
          <a href="/drivers" class="hover:text-blue-700 transition-colors">Repartidores</a>
        </div>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <slot />
    </main>
  </body>
</html>

{
  "name": "@urureparto/api",
  "version": "0.1.0",
  "private": true,
  "description": "UruReparto API — Cloudflare Workers + Hono + D1",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "deploy:dev": "wrangler deploy --env dev",
    "db:migrate": "wrangler d1 execute urureparto-db --file=./src/db/schema.sql",
    "db:migrate:local": "wrangler d1 execute urureparto-db --local --file=./src/db/schema.sql"
  },
  "dependencies": {
    "hono": "^4.6.20",
    "@hono/zod-validator": "^0.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241224.0",
    "typescript": "^5.7.2",
    "wrangler": "^3.101.0",
    "@urureparto/shared": "^0.1.0"
  }
}

    "expo-router": "^56.2.11",
    "expo-secure-store": "^56.0.4",
    "expo-status-bar": "^56.0.4",
    "react": "^19.2.0",
    "react-native": "^0.86.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "^19.2.17",
    "typescript": "^5.7.2"
  }
